{
  "all": true,
  "include": ["app/**/*.ts"],
  "exclude": [
    "app/exceptions/**",
    "tests/**",
    "**/*.spec.ts",
    "app/payments/application/dto/**",
    "app/payments/**/*.types.ts"
  ],
  "reporter": ["text", "text-summary", "html", "lcov"],
  "check-coverage": true,
  "lines": 80,
  "branches": 80,
  "functions": 80,
  "statements": 80
}
